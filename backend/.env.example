# Database connection URL (asyncpg format)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/product_verification

# Server Configuration
HOST=127.0.0.1
PORT=8000

# Directory for storing verification photos
UPLOAD_DIR=uploads

# CORS settings (comma-separated list of origins)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
